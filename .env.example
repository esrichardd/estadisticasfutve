# ─── PostgreSQL ───────────────────────────────────────────────
POSTGRES_USER=admin
POSTGRES_PASSWORD=changeme
POSTGRES_DB=appdb

# URL de conexión async para SQLAlchemy (uso interno entre contenedores)
DATABASE_URL=postgresql+asyncpg://admin:changeme@postgres:5432/appdb

# ─── Backend ──────────────────────────────────────────────────
# Entorno de ejecución: development | production
ENVIRONMENT=development
# Orígenes permitidos para CORS (separados por coma si hay más de uno)
CORS_ORIGINS=["http://localhost:3000"]
# API key requerida en el header x-api-key para todos los endpoints /api/v1/*
API_KEY=cambia-esto-por-algo-secreto

# ─── pgAdmin ──────────────────────────────────────────────────
PGADMIN_DEFAULT_EMAIL=tu@email.com
PGADMIN_DEFAULT_PASSWORD=changeme

# ─── NextJS ───────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000

# URL del backend accesible desde el servidor de Next (solo SSR, nunca expuesto al browser)
# En local puede ser igual a NEXT_PUBLIC_API_URL.
# En Docker: http://backend:8000 (nombre del servicio interno)
BACKEND_API_URL=http://localhost:8000

# API key del backend. Debe coincidir con API_KEY en el .env del backend.
BACKEND_API_KEY=cambia-esto-por-algo-secreto
